rules_version = '2';

// =====================================================================
// INSIGNIA — Cloud Storage security rules
// ---------------------------------------------------------------------
// We keep three folders in the bucket:
//   - customer-artwork/  — uploaded by anonymous customers from the
//                          order builder. Write-only for the public;
//                          admins can read.
//   - product_mockups/   — uploaded by admins (product catalog images).
//                          Public read so the storefront shows them.
//   - order-mockups/     — uploaded by admins (per-order proofs).
//                          Public read so customers see mockups on the
//                          approval page.
// =====================================================================
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }
    function isApprovedAdmin() {
      // Avoid cross-service Firestore lookup (which needs extra IAM
      // configuration on this project). Instead: require Firebase Auth,
      // and exclude customer custom tokens which carry { customer: true }
      // — only real admin sign-ins (email/password Firebase Auth) pass.
      return isSignedIn() && request.auth.token.customer != true;
    }
    function reasonableImage() {
      // < 10 MB and an image content-type
      return request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    // Broader file types for admin-uploaded customer files (artwork
    // sources from customers, reference photos, etc.). Allows
    // images, PDFs, vector formats (AI/EPS/SVG), and common docs.
    function reasonableFile() {
      return request.resource != null
        && request.resource.size < 50 * 1024 * 1024;  // 50 MB cap
    }

    // Customer artwork uploads — write open to the public (storefront
    // form), reads admin-only. Customers don't need to list this folder.
    match /customer-artwork/{file=**} {
      allow create: if reasonableImage();
      allow read:   if isApprovedAdmin();
      allow update, delete: if isApprovedAdmin();
    }

    // Customer files attached to an order by admin (source artwork,
    // reference photos, brand guidelines, etc.). Admin-only on every
    // operation; customers never list or read these directly.
    // Path: order-files/{orderId}/{filename}
    match /order-files/{orderId}/{file=**} {
      allow read, write: if isApprovedAdmin() && reasonableFile();
    }

    // Admin-managed product images — public read, admin write
    match /product_mockups/{file=**} {
      allow read;
      allow create, update, delete: if isApprovedAdmin() && reasonableImage();
    }

    // Per-order mockups uploaded by admin, viewed by customer on
    // approval page — public read, admin write
    match /order-mockups/{file=**} {
      allow read;
      allow create, update, delete: if isApprovedAdmin() && reasonableImage();
    }

    // Legacy path used by an older migration helper; admin-only
    match /mockups/{file=**} {
      allow read;
      allow create, update, delete: if isApprovedAdmin() && reasonableImage();
    }

    // Default deny everything else
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
